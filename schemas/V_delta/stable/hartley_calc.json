                    "constraints": {}
                },
                {
                    "name": "y_sampling",
                    "type": "double",
                    "blank_value": 0,
                    "default_value": 1,
                    "mustBeNonEmpty": false,
                    "mustBeScalar": true,
                    "mustNotHaveNaN": false,
                    "queryable": true,
                    "ontology": null,
