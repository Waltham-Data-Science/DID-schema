{
    "_classname":     "vmneuralresponseresiduals",
    "_class_version": "1.0.0",
    "_superclasses": [
        { "_classname": "base", "_schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "_depends_on": [
        {
            "_name":           "element_id",
            "_mustBeNonEmpty": true,
            "_documentation":  "The document ID of the neuron element this residuals analysis is associated with."
        },
        {
            "_name":           "vmspikefit_id",
            "_mustBeNonEmpty": true,
            "_documentation":  "The document ID of the Vm-spike fit this residual analysis was computed from."
        }
    ],
    "_file": [
        {
            "_name":           "residuals_file",
            "_documentation":  "The file containing the neural response residual data."
        }
    ],
    "_fields": [
        {
            "_name":           "mean_residual",
            "type":           "double",
            "_blank_value":    0.0,
            "_default_value":  0.0,
            "_mustBeNonEmpty": false,
            "_mustBeScalar":   true,
            "_mustNotHaveNaN": false,
            "_queryable":      false,
            "_ontology":       null,
            "_documentation":  "The mean residual of the Vm-to-firing-rate fit.",
            "_constraints":    {}
        }
    ]
}
