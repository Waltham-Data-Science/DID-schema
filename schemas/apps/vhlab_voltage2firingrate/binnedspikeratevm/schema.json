{
    "_classname":     "binnedspikeratevm",
    "_class_version": "1.0.0",
    "_superclasses": [
        { "_classname": "base", "_schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "_depends_on": [
        {
            "_name":           "element_id",
            "_mustBeNonEmpty": true,
            "_documentation":  "The document ID of the neuron element this binned spike rate was computed from."
        }
    ],
    "_file": [
        {
            "_name":           "binnedspikeratevm_file",
            "_documentation":  "The file containing binned spike rate and Vm data."
        }
    ],
    "_fields": [
        {
            "_name":           "bin_size",
            "type":           "double",
            "_blank_value":    0.0,
            "_default_value":  0.001,
            "_mustBeNonEmpty": true,
            "_mustBeScalar":   true,
            "_mustNotHaveNaN": true,
            "_queryable":      true,
            "_ontology":       null,
            "_documentation":  "The bin size in seconds for computing the binned spike rate.",
            "_constraints":    {}
        },
        {
            "_name":           "num_bins",
            "type":           "integer",
            "_blank_value":    0,
            "_default_value":  0,
            "_mustBeNonEmpty": false,
            "_mustBeScalar":   true,
            "_mustNotHaveNaN": true,
            "_queryable":      false,
            "_ontology":       null,
            "_documentation":  "The total number of bins.",
            "_constraints":    {}
        }
    ]
}
