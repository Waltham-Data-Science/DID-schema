{
    "classname":     "vmspikefit",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the neuron element this Vm-spike fit is associated with."
        }
    ],
    "file": [
        {
            "name":           "vmspikefit_file",
            "documentation":  "The file containing the Vm-to-spike-rate fit data."
        }
    ],
    "fields": [
        {
            "name":           "fit_function",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the function used to fit Vm to firing rate (e.g., 'threshold_linear', 'rectified_power').",
            "constraints":    { "max_length": 128 }
        },
        {
            "name":           "fit_parameters",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "JSON object of the fitted parameter values.",
            "constraints":    {}
        },
        {
            "name":           "r_squared",
            "type":           "double",
            "blank_value":    0.0,
            "default_value":  0.0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "R-squared goodness-of-fit value.",
            "constraints":    {}
        }
    ]
}
