{
    "classname":     "valid_interval",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the element whose valid intervals are marked."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "intervals",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Nx2 matrix of valid (non-garbage) time intervals in seconds, where N equals num_intervals. Each row is [t_start, t_end] with t_start < t_end.",
            "constraints":    { "element_type": "double", "shape": "Nx2" }
        },
        {
            "name":           "num_intervals",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The number of valid intervals.",
            "constraints":    {}
        }
    ]
}
