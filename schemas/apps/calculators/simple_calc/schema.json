{
    "classname":     "simple_calc",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the element this calculation is associated with."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "calculator_name",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the calculator that produced this result.",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "result_value",
            "type":           "double",
            "blank_value":    0.0,
            "default_value":  0.0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "The scalar result value of the calculation.",
            "constraints":    {}
        },
        {
            "name":           "result_units",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The units of the result value.",
            "constraints":    { "max_length": 64 }
        }
    ]
}
