{
    "classname":     "ontologyLabel",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": false,
            "documentation":  "The document ID of the element this ontology label is associated with."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "ontology_name",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the ontology (e.g., 'Allen CCF v3').",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "label",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The ontology label assigned to this element (e.g., brain region name).",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "label_id",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The numeric identifier of the ontology label.",
            "constraints":    {}
        }
    ]
}
