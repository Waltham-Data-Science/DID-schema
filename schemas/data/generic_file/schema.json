{
    "classname":     "generic_file",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": false,
            "documentation":  "The document ID of the element this file is associated with."
        }
    ],
    "file": [
        {
            "name":           "data_file",
            "documentation":  "The generic data file."
        }
    ],
    "fields": [
        {
            "name":           "filename",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The original filename of the data file.",
            "constraints":    { "max_length": 512 }
        },
        {
            "name":           "mimetype",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "application/octet-stream",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The MIME type of the data file.",
            "constraints":    { "max_length": 128 }
        },
        {
            "name":           "description",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "A free-text description of the file contents.",
            "constraints":    { "max_length": 1024 }
        }
    ]
}
