{
    "_classname": "fitcurve",
    "_class_version": "1.0.0",
    "_maturity_level": "work_in_progress",
    "_superclasses": [
        {
            "_classname": "base",
            "_schema": "$NDISCHEMAPATH/base/schema.json"
        }
    ],
    "_depends_on": [
        {
            "_name": "element_id",
            "_mustBeNonEmpty": false,
            "_documentation": "The document ID of the element this fit curve is associated with."
        }
    ],
    "_file": [],
    "_fields": [
        {
            "_name": "fit_function",
            "type": "char",
            "_blank_value": "",
            "_default_value": "",
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": false,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "The name or formula of the fitting function (e.g., 'gaussian', 'sigmoid', 'polynomial').",
            "_constraints": {
                "max_length": 256
            }
        },
        {
            "_name": "fit_parameters",
            "type": "structure",
            "_blank_value": {},
            "_default_value": {},
            "_mustBeNonEmpty": false,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": false,
            "_queryable": false,
            "_ontology": null,
            "_documentation": "Structure of fitted parameter values keyed by parameter name. Keys and value types depend on fit_function (e.g., for 'gaussian': {mean, sigma, amplitude, offset}).",
            "_constraints": {
                "dynamic_keys_from": "fit_function"
            },
            "_fields": []
        },
        {
            "_name": "goodness_of_fit",
            "type": "double",
            "_blank_value": 0.0,
            "_default_value": 0.0,
            "_mustBeNonEmpty": false,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": false,
            "_queryable": false,
            "_ontology": null,
            "_documentation": "A goodness-of-fit statistic (e.g., R-squared value).",
            "_constraints": {}
        },
        {
            "_name": "goodness_of_fit_type",
            "type": "char",
            "_blank_value": "",
            "_default_value": "r_squared",
            "_mustBeNonEmpty": false,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": false,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "The type of goodness-of-fit measure (e.g., 'r_squared', 'rmse', 'chi_squared').",
            "_constraints": {
                "max_length": 64
            }
        }
    ]
}
