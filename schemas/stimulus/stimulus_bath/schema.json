{
    "classname":     "stimulus_bath",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the element receiving this bath stimulus."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "solution_name",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the bath solution (e.g., 'ACSF', 'TTX').",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "concentration",
            "type":           "double",
            "blank_value":    0.0,
            "default_value":  0.0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "The concentration of the active compound.",
            "constraints":    {}
        },
        {
            "name":           "concentration_units",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The units of the concentration (e.g., 'mM', 'uM', 'nM').",
            "constraints":    { "max_length": 32 }
        }
    ]
}
