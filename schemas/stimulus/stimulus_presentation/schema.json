{
    "classname":     "stimulus_presentation",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the element associated with this stimulus presentation."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "stimulus_type",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The type of stimulus presented (e.g., 'grating', 'noise', 'natural_image').",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "presentation_order",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": true,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Array of integer stimulus indices (1-based) in the order they were presented. Length equals num_trials.",
            "constraints":    { "element_type": "integer" }
        },
        {
            "name":           "num_trials",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The total number of stimulus trials.",
            "constraints":    {}
        }
    ]
}
