{
    "classname":     "stimulus_tuningcurve",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "stimulus_response_scalar_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the stimulus_response_scalar this tuning curve was derived from."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "independent_variable",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the independent stimulus variable (e.g., 'angle', 'spatial_frequency').",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "independent_values",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Array of numeric values of the independent variable, one per tuning curve point. Must be the same length as response_mean and response_stderr.",
            "constraints":    { "element_type": "double" }
        },
        {
            "name":           "response_mean",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Array of mean response values at each point in independent_values. Must be the same length as independent_values.",
            "constraints":    { "element_type": "double" }
        },
        {
            "name":           "response_stderr",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Array of standard error of the mean for each response value. Must be the same length as independent_values.",
            "constraints":    { "element_type": "double" }
        }
    ]
}
