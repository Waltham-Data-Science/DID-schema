{
    "classname":     "probe_geometry",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "probe_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the probe whose geometry is described."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "num_channels",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The total number of channels on the probe.",
            "constraints":    {}
        },
        {
            "name":           "channel_positions",
            "type":           "matrix",
            "blank_value":    [],
            "default_value":  [],
            "mustBeNonEmpty": false,
            "mustBeScalar":   false,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Nx2 matrix of channel positions in position_units, where N equals num_channels. Each row is [x, y] giving the spatial location of that channel on the probe.",
            "constraints":    { "element_type": "double", "shape": "Nx2" }
        },
        {
            "name":           "position_units",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "um",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "The units for channel positions (e.g., 'um', 'mm').",
            "constraints":    { "max_length": 32 }
        },
        {
            "name":           "probe_type",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The type or model of the probe (e.g., 'Neuropixels 1.0', 'tetrode').",
            "constraints":    { "max_length": 256 }
        }
    ]
}
