{
    "classname":     "oneepoch",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" },
        { "classname": "epochid", "schema": "$NDISCHEMAPATH/epochid/schema.json" }
    ],
