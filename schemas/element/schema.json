{
    "classname":     "element",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "underlying_element_id",
            "mustBeNonEmpty": false,
            "documentation":  "The document ID of the underlying element, if this element derives from another."
        },
        {
            "name":           "subject_id",
            "mustBeNonEmpty": false,
            "documentation":  "The document ID of the subject associated with this element."
        }
    ],
    "file":          [],
    "fields": [
        {
            "name":           "ndi_element_class",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "ndi_element",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the NDI element class that is stored.",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "element_name",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology": {
                "namespace": "schema",
                "term":      "name",
                "uri":       "https://schema.org/name"
            },
            "documentation":  "The name of the element. Elements are uniquely defined by name, reference, and type.",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "reference",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "1",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The reference number of the element.",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "element_type",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The type of the element. Common probe types are defined in probetype2object.",
            "constraints":    { "max_length": 256 }
        },
        {
            "name":           "direct",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "Does this element directly feed data from an underlying element? 0 for no, 1 for yes.",
            "constraints":    { "min": 0, "max": 1 }
        }
    ]
}
