{
    "classname":     "SpikeInterfaceSortingOutputs",
    "class_version": "1.0.0",
    "superclasses": [
        { "classname": "base", "schema": "$NDISCHEMAPATH/base/schema.json" }
    ],
    "depends_on": [
        {
            "name":           "element_id",
            "mustBeNonEmpty": true,
            "documentation":  "The document ID of the element (e.g., probe) this sorting output is associated with."
        }
    ],
    "file": [
        {
            "name":           "sorting_output_file",
            "documentation":  "The SpikeInterface sorting output file."
        }
    ],
    "fields": [
        {
            "name":           "sorter_name",
            "type":           "char",
            "blank_value":    "",
            "default_value":  "",
            "mustBeNonEmpty": true,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The name of the spike sorter used (e.g., 'kilosort2', 'mountainsort4').",
            "constraints":    { "max_length": 128 }
        },
        {
            "name":           "num_units",
            "type":           "integer",
            "blank_value":    0,
            "default_value":  0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": true,
            "queryable":      true,
            "ontology":       null,
            "documentation":  "The number of units (clusters) found by the sorter.",
            "constraints":    {}
        },
        {
            "name":           "sample_rate",
            "type":           "double",
            "blank_value":    0.0,
            "default_value":  0.0,
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "The sampling rate in Hz of the recording that was sorted.",
            "constraints":    {}
        },
        {
            "name":           "sorter_parameters",
            "type":           "structure",
            "blank_value":    {},
            "default_value":  {},
            "mustBeNonEmpty": false,
            "mustBeScalar":   true,
            "mustNotHaveNaN": false,
            "queryable":      false,
            "ontology":       null,
            "documentation":  "Structure of the parameters used to run the sorter. Keys and value types are specific to the algorithm named in sorter_name (e.g., for 'kilosort2': {detect_threshold, projection_threshold, ...}).",
            "constraints":    { "dynamic_keys_from": "sorter_name" },
            "fields":         []
        }
    ]
}
