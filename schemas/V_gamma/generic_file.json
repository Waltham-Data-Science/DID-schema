            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": true,
            "ontology": null,
            "documentation": "The original filename of the data file.",
            "constraints": {
                "maxLength": 512
            }
        },
        {
            "name": "mimetype",
            "type": "char",
            "blank_value": "",
            "default_value": "application/octet-stream",
            "mustBeNonEmpty": false,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": true,
            "ontology": null,
            "documentation": "The MIME type of the data file.",
            "constraints": {
                "maxLength": 128
            }
        },
        {
            "name": "description",
            "type": "char",
            "blank_value": "",
            "default_value": "",
            "mustBeNonEmpty": false,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": false,
            "ontology": null,
            "documentation": "A free-text description of the file contents.",
            "constraints": {
                "maxLength": 1024
            }
        }
    ]
