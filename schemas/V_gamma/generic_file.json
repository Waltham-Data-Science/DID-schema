{
    "document_class": {
        "class_name": "generic_file",
        "class_version": "1.0.0",
        "superclasses": [
            {
                "class_name": "base",
                "schema": "$NDISCHEMAPATH/base/schema.json"
            }
        ],
        "maturity_level": "work_in_progress"
    },
    "depends_on": [
        {
            "name": "element_id",
            "mustBeNonEmpty": false,
            "documentation": "The document ID of the element this file is associated with.",
            "must_refer_to_document_class": ""
        }
    ],
    "file": [
        {
            "name": "data_file",
            "documentation": "The generic data file."
        }
    ],
    "fields": [
        {
            "name": "filename",
            "type": "char",
            "blank_value": "",
            "default_value": "",
