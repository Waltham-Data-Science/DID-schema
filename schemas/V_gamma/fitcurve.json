{
    "document_class": {
        "class_name": "fitcurve",
        "class_version": "1.0.0",
        "superclasses": [
            {
                "class_name": "base",
                "schema": "$NDISCHEMAPATH/base/schema.json"
            }
        ]
    },
    "maturity_level": "work_in_progress",
    "depends_on": [
        {
            "name": "element_id",
            "mustBeNonEmpty": false,
            "documentation": "The document ID of the element this fit curve is associated with.",
            "must_refer_to_document_class": ""
        }
    ],
    "file": [],
    "fields": [
        {
            "name": "fit_function",
            "type": "char",
            "blank_value": "",
            "default_value": "",
            "mustBeNonEmpty": true,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": true,
            "ontology": null,
            "documentation": "The name or formula of the fitting function (e.g., 'gaussian', 'sigmoid', 'polynomial').",
            "constraints": {
                "maxLength": 256
            }
        },
        {
            "name": "fit_parameters",
            "type": "structure",
            "blank_value": {},
            "default_value": {},
            "mustBeNonEmpty": false,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": false,
            "ontology": null,
            "documentation": "Structure of fitted parameter values keyed by parameter name. Keys and value types depend on fit_function (e.g., for 'gaussian': {mean, sigma, amplitude, offset}).",
            "constraints": {
                "dynamic_keys_from": "fit_function"
            },
            "fields": []
        },
        {
            "name": "goodness_of_fit",
            "type": "double",
            "blank_value": 0.0,
            "default_value": 0.0,
            "mustBeNonEmpty": false,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": false,
            "ontology": null,
            "documentation": "A goodness-of-fit statistic (e.g., R-squared value).",
            "constraints": {}
        },
        {
            "name": "goodness_of_fit_type",
            "type": "char",
            "blank_value": "",
            "default_value": "r_squared",
            "mustBeNonEmpty": false,
            "mustBeScalar": true,
            "mustNotHaveNaN": false,
            "queryable": true,
            "ontology": null,
            "documentation": "The type of goodness-of-fit measure (e.g., 'r_squared', 'rmse', 'chi_squared').",
            "constraints": {
                "maxLength": 64
            }
        }
    ]
}
