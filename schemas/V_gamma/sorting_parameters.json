{
    "_classname": "sorting_parameters",
    "_class_version": "1.0.0",
    "_maturity_level": "work_in_progress",
    "_superclasses": [
        {
            "_classname": "base",
            "_schema": "$NDISCHEMAPATH/base/schema.json"
        }
    ],
    "_depends_on": [
        {
            "_name": "element_id",
            "_mustBeNonEmpty": true,
            "_documentation": "The document ID of the element (e.g., probe) these sorting parameters apply to.",
            "_must_refer_to_document_class": ""
        }
    ],
    "_file": [],
    "_fields": [
        {
            "_name": "sorter_name",
            "type": "char",
            "_blank_value": "",
            "_default_value": "",
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": false,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "The name of the spike sorting algorithm.",
            "_constraints": {
                "maxLength": 128
            }
        },
        {
            "_name": "graphical_mode",
            "type": "integer",
            "_blank_value": 0,
            "_default_value": 0,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": false,
            "_ontology": null,
            "_documentation": "Whether to use a graphical presentation during sorting (0 = no, 1 = yes).",
            "_constraints": {
                "min": 0,
                "max": 1
            }
        },
        {
            "_name": "num_pca_features",
            "type": "integer",
            "_blank_value": 10,
            "_default_value": 10,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "Number of principal component features to use in clustering.",
            "_constraints": {
                "min": 1
            }
        },
        {
            "_name": "interpolation",
            "type": "integer",
            "_blank_value": 3,
            "_default_value": 3,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": false,
            "_ontology": null,
            "_documentation": "Interpolation factor for spike waveforms. Waveforms are upsampled by this integer factor to provide extra resolution during alignment and clustering (e.g., 3 means 3x upsampling). Set to 1 for no interpolation.",
            "_constraints": {
                "min": 1
            }
        },
        {
            "_name": "min_clusters",
            "type": "integer",
            "_blank_value": 3,
            "_default_value": 3,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "Minimum number of clusters (units) to produce.",
            "_constraints": {
                "min": 1
            }
        },
        {
            "_name": "max_clusters",
            "type": "integer",
            "_blank_value": 10,
            "_default_value": 10,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": true,
            "_ontology": null,
            "_documentation": "Maximum number of clusters (units) to produce. Must be >= min_clusters.",
            "_constraints": {
                "min": 1
            }
        },
        {
            "_name": "num_start",
            "type": "integer",
            "_blank_value": 5,
            "_default_value": 5,
            "_mustBeNonEmpty": true,
            "_mustBeScalar": true,
            "_mustNotHaveNaN": true,
            "_queryable": false,
            "_ontology": null,
            "_documentation": "Initial number of clusters to seed the clustering algorithm with.",
            "_constraints": {
                "min": 1
            }
        }
    ]
}
